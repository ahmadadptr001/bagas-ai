# ============================================================
#  Konfigurasi AI Agent (NVIDIA free API)
#  Salin file ini menjadi ".env" lalu isi nilainya.
#    cp .env.example .env   (Linux/Mac)
#    copy .env.example .env (Windows)
# ============================================================

# --- WAJIB: API key NVIDIA ---
# Dapatkan gratis di https://build.nvidia.com -> buka model apa saja -> "Get API Key"
# Formatnya diawali "nvapi-..."
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoint (biasanya tidak perlu diubah)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Model per-tugas (boleh diganti dengan model lain dari katalog NVIDIA) ---
# Semua model diambil dari https://build.nvidia.com/models (gratis di free tier).
#
# Model chat utama WAJIB mendukung tool/function calling. Pilihan lain:
#   z-ai/glm-5.2                             (default; jago agentic & coding)
#   meta/llama-3.3-70b-instruct              (seimbang)
#   mistralai/mistral-large-3-675b-instruct-2512  (paling pintar, lebih lambat)
#   nvidia/llama-3.3-nemotron-super-49b-v1.5 (Nemotron NVIDIA, cepat & murah)
CHAT_MODEL=z-ai/glm-5.2
#
# Model untuk analisis gambar (vision / VLM). Pilihan lain:
#   meta/llama-3.2-90b-vision-instruct       (default; 128k konteks)
#   meta/llama-3.2-11b-vision-instruct       (lebih ringan & cepat)
#   microsoft/phi-3-vision-128k-instruct
VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# Catatan SPEECH: model suara NVIDIA (Parakeet/Canary ASR, Magpie TTS) TIDAK
# lewat endpoint OpenAI-compatible ini, melainkan via Riva/endpoint terpisah.
# Karena itu speech-to-text/text-to-speech masih fitur lanjutan.

# --- CONNECTOR web-AI (opsional; via browser, BUKAN NVIDIA) ---
# Hubungkan bagas-ai ke AI web berbasis chat (claude.ai, chat.qwen.ai) sebagai
# "model": ketik /model claude-web atau /model qwen-web. Butuh Playwright:
#   pip install playwright && playwright install chromium
# Jendela Chrome MUNCUL sekali untuk login lalu DI-MINIMIZE; chat & jawaban tampil
# di TERMINAL (sesi login disimpan di ~/.bagasai/browser). Jendela tetap ada (bukan
# headless) karena Cloudflare menolak sesi headless — inilah default yang andal.
# CONNECTOR_HEADLESS=true    # paksa headless sejati (tanpa jendela); hanya utk situs tanpa Cloudflare
# CONNECTOR_BROWSER_CHANNEL=chrome  # pakai Chrome asli (default); "" -> Chromium bawaan
# Tiap sesi bagas-ai membuat 1 percakapan baru di situs. Batas ini menyisakan N
# percakapan TERBARU buatan bagas-ai; sisanya dihapus otomatis (chat pribadimu
# TIDAK disentuh). 0 = jangan hapus otomatis; bersihkan manual lewat /web.
# CONNECTOR_KEEP_CHATS=20

# --- Bot Telegram (opsional; hanya perlu jika menjalankan mode telegram) ---
# Dapatkan token dari @BotFather di Telegram.
TELEGRAM_BOT_TOKEN=
# ID Telegram yang BOLEH mengontrol bagas-ai (pisah koma). WAJIB diisi demi
# keamanan: lewat Telegram bagas-ai bisa menjalankan perintah & menulis file di
# laptopmu. Kosongkan -> pengirim pertama otomatis jadi pemilik (lalu ID-nya
# diberitahukan agar bisa kamu tempel di sini). Cek ID-mu via @userinfobot.
TELEGRAM_ALLOWED_IDS=

# --- Pengaturan agent ---
# Batas iterasi loop tool-calling (hemat kuota 40 RPM).
MAX_TOOL_ITERATIONS=8
# Suhu sampling (0.0 - 1.0). Lebih rendah = lebih fokus.
TEMPERATURE=0.6

# --- Keamanan eksekusi kode ---
# true  = tool eksekusi kode/perintah aktif (hati-hati!)
# false = matikan total eksekusi kode
ALLOW_CODE_EXEC=true
# Timeout eksekusi kode dalam detik.
CODE_EXEC_TIMEOUT=30
