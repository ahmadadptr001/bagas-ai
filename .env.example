# ============================================================
#  Konfigurasi bagas-ai
#  Salin file ini menjadi ".env" lalu isi nilainya — SEMUANYA opsional.
#    cp .env.example .env   (Linux/Mac)
#    copy .env.example .env (Windows)
# ============================================================
#
# TIDAK ADA API KEY di sini. Seluruh model bagas-ai berjalan lewat BROWSER
# memakai akun yang sudah kamu pakai sehari-hari (Kimi/Claude/Qwen): login
# cukup SEKALI di jendela Chrome saat kamu memilih model lewat /model, dan
# sesinya tersimpan di ~/.bagasai/browser.
#
# Katalog model NVIDIA beserta NVIDIA_API_KEY, NVIDIA_BASE_URL, VISION_MODEL,
# TEMPERATURE, dan setelan retry/timeout endpoint sudah DIHAPUS. Baris-baris itu
# boleh dibiarkan di .env lamamu — semuanya diabaikan begitu saja.

# --- Model bawaan ---
# Pilihan: web/kimi (default) - web/claude - web/qwen
# Bisa diganti kapan saja lewat /model; pilihan terakhir otomatis tersimpan.
CHAT_MODEL=web/kimi

# --- Connector browser ---
# Butuh Playwright (dipasang otomatis oleh installer):
#   pip install playwright && playwright install chromium
# Jendela Chrome MUNCUL sekali untuk login lalu disembunyikan; chat & jawaban
# tampil di TERMINAL. Jendela tetap ada (bukan headless) karena Cloudflare
# menolak sesi headless — inilah default yang andal.
# CONNECTOR_HEADLESS=true          # paksa headless; hanya utk situs tanpa Cloudflare
# CONNECTOR_SHOW=true              # tampilkan jendela terus (mengamati prosesnya)
# CONNECTOR_BROWSER_CHANNEL=chrome # Chrome asli (default); "" -> Chromium bawaan
# Tiap sesi bagas-ai membuat 1 percakapan baru di situs. Batas ini menyisakan N
# percakapan TERBARU buatan bagas-ai; sisanya dihapus otomatis (chat pribadimu
# TIDAK disentuh). 0 = jangan hapus otomatis; bersihkan manual lewat /web.
# CONNECTOR_KEEP_CHATS=20

# --- Bot Telegram (opsional; hanya perlu jika menjalankan mode telegram) ---
# Dapatkan token dari @BotFather di Telegram.
TELEGRAM_BOT_TOKEN=
# ID Telegram yang BOLEH mengontrol bagas-ai (pisah koma). WAJIB diisi demi
# keamanan: lewat Telegram bagas-ai bisa menjalankan perintah & menulis file di
# laptopmu. Kosongkan -> pengirim pertama otomatis jadi pemilik (lalu ID-nya
# diberitahukan agar bisa kamu tempel di sini). Cek ID-mu via @userinfobot.
TELEGRAM_ALLOWED_IDS=

# --- Pengaturan agent ---
# Batas iterasi loop tool per giliran.
MAX_TOOL_ITERATIONS=8

# --- Keamanan eksekusi kode ---
# true  = tool eksekusi kode/perintah aktif (hati-hati!)
# false = matikan total eksekusi kode
ALLOW_CODE_EXEC=true
# Timeout eksekusi kode dalam detik.
CODE_EXEC_TIMEOUT=30
